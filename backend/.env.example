# Database - Supabase PostgreSQL
# Get this from: Supabase Dashboard → Settings → Database → Connection string
# Format: postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxxxxxxx.supabase.co:5432/postgres
# For connection pooling (recommended): use port 6543 instead of 5432
DATABASE_URL=postgresql://postgres:your_password@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# Supabase (Optional - if using Supabase Auth instead of custom JWT)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-public-key

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Email
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@plataforma-educativa.com

# Cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# CORS (comma-separated list, add your Vercel domain when deployed)
CORS_ORIGINS=http://localhost:3000,https://localhost:3000,https://your-app.vercel.app
